# PrinterArchive environment variables (copy to .env.local for local use).
# Never commit real secrets. The values below are placeholders.

# IndexNow verification key. Must equal the stem of the committed public key
# file at public/<INDEXNOW_KEY>.txt (the search engines fetch that file to
# verify ownership). Used only by scripts/indexnow-submit.mjs — never by the
# rendered site. Leave blank to disable submission.
INDEXNOW_KEY=

# Optional overrides for the IndexNow submitter (defaults shown):
# SITE_URL=https://printerarchive.net
# SITEMAP_URL=https://printerarchive.net/sitemap.xml
# INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow
